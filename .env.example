# Auth (set in production; do not leave defaults)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
# ADMIN_TOKEN=change-me

# CORS (production: comma-separated origins, e.g. https://app.example.com)
# CORS_ORIGINS=

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/minuteslm

# Storage
AUDIO_UPLOAD_DIR=uploads/audio
MAX_UPLOAD_MB=100

# ASR (Whisper v3 Turbo). Long audio is split into chunks and transcribed per chunk.
WHISPER_MODEL=turbo-v3
TRANSCRIPTION_CHUNK_DURATION_SEC=600

# LLM (Ollama) — pull first: ollama pull qwen3.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5
# Context window (e.g. qwen3.5 = 4096). Long meetings are chunked automatically.
OLLAMA_CONTEXT_TOKENS=4096
OLLAMA_MAX_OUTPUT_TOKENS=2048
# Log full prompt to backend console when formatting (debug why format is not followed)
# LOG_LLM_PROMPT=1
