# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/minuteslm

# Storage
AUDIO_UPLOAD_DIR=uploads/audio
MAX_UPLOAD_MB=100

# ASR (Whisper v3 Turbo)
WHISPER_MODEL=turbo-v3

# LLM (Ollama) — pull first: ollama pull qwen3.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5
# Context window (e.g. qwen3.5 = 4096). Long meetings are chunked automatically.
OLLAMA_CONTEXT_TOKENS=4096
OLLAMA_MAX_OUTPUT_TOKENS=2048
